# --- Database ---
MYSQL_ROOT_PASSWORD=isi_password_root_kuat
MYSQL_PASSWORD=isi_password_user_posturfit
DATABASE_URL=mysql+pymysql://posturfit:${MYSQL_PASSWORD}@mysql:3306/posturfit

# --- JWT Authentication ---
JWT_SECRET_KEY=ganti-dengan-secret-key-panjang-dan-acak
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- Session Admin Dashboard ---
SESSION_SECRET=ganti-dengan-session-secret-panjang-dan-acak

# --- MongoDB Atlas (Sync Edukasi) ---
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# --- OTP Email (SMTP Gmail) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=emailmu@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
OTP_EXPIRE_MINUTES=10

# --- Gemini AI (LLM Rekomendasi) ---
GEMINI_API_KEY=ganti-dengan-gemini-api-key-anda

# --- Google reCAPTCHA ---
RECAPTCHA_SITE_KEY=ganti-dengan-recaptcha-site-key
RECAPTCHA_SECRET_KEY=ganti-dengan-recaptcha-secret-key
